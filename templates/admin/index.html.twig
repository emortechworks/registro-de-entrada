{% extends 'base.html.twig' %}

{% block title %}
  <title>Panel de Administración - INE</title>
{% endblock %}

{% block body %}
  <main class="container mt-5">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
      <i class="bi bi-shield-lock-fill text-primary fs-1 me-3"></i>
      <div>
        <h1 class="h2 mb-0">Panel de Control Administrativo</h1>
        <p class="text-muted text-center mb-0">Gestión de usuarios y reportes.</p>
      </div>
    </div>

    <div class="row g-4">
      {# Opción 1: Gestión de Usuarios #}
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body text-center p-4">
            <div class="mb-3">
              <i class="bi bi-people-fill text-primary" style="font-size: 2.5rem;"></i>
            </div>
            <h5 class="card-title fw-bold">Administrar Usuarios</h5>
            <p class="card-text text-muted small">Alta, baja y modificación de administradores del sitio</p>
            <a href="#" class="btn btn-outline-primary w-100 mt-2"><i class="bi bi-gear-fill me-1"></i> Gestionar</a>
          </div>
        </div>
      </div>

      {# Opción 2: Reportes y Estadísticas #}
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body text-center p-4">
            <div class="mb-3">
              <i class="bi bi-file-earmark-bar-graph-fill text-success" style="font-size: 2.5rem;"></i>
            </div>
            <h5 class="card-title fw-bold">Reportes</h5>
            <p class="card-text text-muted small">Reportes de entradas y salidas de las instalaciones.</p>
            <a href="#" class="btn btn-outline-success w-100 mt-2"><i class="bi bi-download me-1"></i> Generar Reporte</a>
          </div>
        </div>
      </div>

      {# Opción 3: Bitácora en Tiempo Real #}
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body text-center p-4">
            <div class="mb-3">
              <i class="bi bi-clock-history text-warning" style="font-size: 2.5rem;"></i>
            </div>
            <h5 class="card-title fw-bold">Bitácora de Hoy</h5>
            <p class="card-text text-muted small">Ver el flujo de personas que han ingresado el día.</p>
            <a href="#" class="btn btn-outline-warning w-100 mt-2 text-dark"><i class="bi bi-eye-fill me-1"></i> Ver Registro</a>
          </div>
        </div>
      </div>
    </div>
  </main>
{% endblock %}
