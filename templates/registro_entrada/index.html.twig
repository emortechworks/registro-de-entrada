{% extends 'base.html.twig' %}

{% block title %}
  RegistroEntrada index
{% endblock %}

{% block body %}
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4 mb-0">Registros de entrada</h1>
      <a href="{{ path('app_registro_entrada_new') }}" class="btn btn-success"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i> Crear nuevo</a>
    </div>

    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Id</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Identificación</th>
                <th>Persona que visita</th>
                <th>Departamento</th>
                <th>Motivo</th>
                <th>Fecha salida</th>
                <th>Hora salida</th>
                <th class="text-end">Acciones</th>
              </tr>
            </thead>
            <tbody>
              {% for registro_entrada in registro_entradas %}
                <tr>
                  <td>{{ registro_entrada.id }}</td>
                  <td>{{ registro_entrada.fechaEntrada ? registro_entrada.fechaEntrada|date('Y-m-d') : '' }}</td>
                  <td>{{ registro_entrada.horaEntrada ? registro_entrada.horaEntrada|date('H:i:s') : '' }}</td>
                  <td>{{ registro_entrada.nombre }}</td>
                  <td>{{ registro_entrada.apellido }}</td>
                  <td>{{ registro_entrada.identificacion }}</td>
                  <td>{{ registro_entrada.personaQueVisita }}</td>
                  <td>{{ registro_entrada.departamentoQueVisita }}</td>
                  <td>{{ registro_entrada.motivoDeVisita }}</td>
                  <td>{{ registro_entrada.fechaSalida ? registro_entrada.fechaSalida|date('Y-m-d') : '' }}</td>
                  <td>{{ registro_entrada.horaSalida ? registro_entrada.horaSalida|date('H:i:s') : '' }}</td>
                  <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary me-1" href="{{ path('app_registro_entrada_show', { id: registro_entrada.id }) }}" title="Ver"><i class="bi bi-eye" aria-hidden="true"></i></a>
                    <a class="btn btn-sm btn-outline-primary me-1" href="{{ path('app_registro_entrada_edit', { id: registro_entrada.id }) }}" title="Editar"><i class="bi bi-pencil" aria-hidden="true"></i></a>
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="12" class="text-center py-4">No se encontraron registros</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
