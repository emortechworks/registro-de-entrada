{% extends 'base.html.twig' %}

{% block title %}
  Editar Usuario
{% endblock %}

{% block body %}
  <main class="container mt-5">
    <div class="row justify-content-center col-12">
      <div class="col-mg-12 col-md-8 col-lg-6">
        {# Encabezado con botón de retorno #}
        <div class="d-flex align-items-center mb-4">
          <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary btn-sm me-3" title="Volver al listado"><i class="bi bi-arrow-left"></i></a>
          <h1 class="h3 mb-0">Editar Usuario</h1>
        </div>

        <div class="card shadow-sm">
          <div class="card-body p-4">
            {# Aqui se incluye el formulario _form.html.twig #}
            {{ include('user/_form.html.twig') }}

            <hr class="my-4" />

            {# aqui se incluye el botn de "delete" delete_form.html.twig #}
            <div class="d-flex justify-content-center">{{ include('user/_delete_form.html.twig') }}</div>
          </div>
        </div>

        <div class="mt-3 text-center">
          <a href="{{ path('app_user_index') }}" class="btn btn-link btn-sm text-secondary"><i class="bi bi-list-ul me-1"></i> Regresar al listado</a>
        </div>
      </div>
    </div>
  </main>
{% endblock %}
