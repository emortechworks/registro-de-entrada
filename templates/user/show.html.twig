{% extends 'base.html.twig' %}

{% block title %}
  Perfil de {{ user.nombre }}
{% endblock %}

{% block body %}
  <main class="container mt-5">
    <div class="d-flex justify-content-center col-12">
      <div class="col-mg-12 col-md-8 col-lg-6">
        {# Encabezado y botón volver #}
        <div class="">
          <h1 class="h3 mt-2 text-center">Información del Usuario</h1>
          <h1 class="h3 mt-2 text-center">{{ user.nombre }} {{ user.apellido }}</h1>
        </div>

        <div class="card shadow">
          <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Detalles de la cuenta</h5>
            <span class="badge bg-light text-primary">ID: #{{ user.id }}</span>
          </div>

          <div class="card-body">
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                <span class="text-muted"><i class="bi bi-info-circle me-2"></i>Nombre completo</span>
                <span class="fw-bold">{{ user.nombre }} {{ user.apellido }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                <span class="fw-bold">{{ user.email }}</span>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                <span class="text-muted"><i class="bi bi-shield-lock me-2"></i>Contraseña</span>
                <span class="text-muted small italic">********</span>
              </li>
            </ul>
          </div>

          <div class="card-footer bg-light d-flex justify-content-end gap-2 py-3">
            <a href="{{ path('app_user_edit', { id: user.id }) }}" class="btn btn-warning"><i class="bi bi-pencil-square me-1"></i> Editar</a>

            <div class="d-inline-block">{{ include('user/_delete_form.html.twig') }}</div>
          </div>
        </div>
      </div>
    </div>

    <a href="{{ path('app_user_index') }}" class="btn btn-link btn-sm text-secondary mt-3"><i class="bi bi-list-ul me-1"></i> Regresar al listado</a>
  </main>
{% endblock %}
