    <div class="card">
      <div class="card-body">
        <h1 class="h5"><i class="bi bi-plus-circle me-2" aria-hidden="true"></i> Crear nuevo registro</h1>

        {{ include('registro_entrada/_form.html.twig', { button_label: 'Guardar' }) }}

        <div class="mt-3">
          <a href="{{ path('app_registro_entrada_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Volver</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
