{% extends 'base.html.twig' %}

{% block title %}
  <title>Acceso Administrativo</title>
{% endblock %}

{% block body %}
  <main class="d-flex container justify-content-center">
    <div class="row justify-content-center col-lg-6 col-md-12 col-sm-12">
      <div class="col-md-12">
        <div class="card shadow border-0">
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <h1 class="h3 mb-3 fw-bold">Acceso administrativo</h1>
              <p class="text-muted">Ingresa tus datos para continuar</p>
            </div>

            <form method="post">
              {% if error %}
                <div class="alert alert-danger py-2 small">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
              {% endif %}

              {% if app.user %}
                <div class="alert alert-info py-2 small mb-3">
                  Ya estás autenticado como <strong>{{ app.user.userIdentifier }}</strong>.
                  <a href="{{ logout_path() }}" class="alert-link">Cerrar sesión</a>
                </div>
              {% endif %}

              <div class="form-floating mb-3">
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" placeholder="nombre@ejemplo.com" required autofocus />
                <label for="username">Correo Electrónico</label>
              </div>

              <div class="form-floating mb-3">
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" placeholder="Contraseña" required />
                <label for="password">Contraseña</label>
              </div>

              <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

              <div class="d-grid mt-4">
                <button class="btn btn-lg btn-primary shadow-sm" type="submit">Entrar</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
{% endblock %}
