{% extends 'base.html.twig' %}

{% block title %}
  <title>Acceso Administrativo</title>
{% endblock %}

{% block body %}
  <main class="d-flex container justify-content-center mt-5">
    <div class="row justify-content-center col-lg-6 col-md-12 col-sm-12">
      <div class="col-md-12">
        <div class="card shadow border-0">
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <div class="mb-2">
                <i class="bi bi-shield-lock-fill text-primary" style="font-size: 3rem;"></i>
              </div>
              <h1 class="h3 mb-3 fw-bold">Acceso administrativo</h1>
              <p class="text-muted">Ingresa tus datos para continuar</p>
            </div>

            <form method="post">
              {% if error %}
                <div class="alert alert-danger py-2 small d-flex align-items-center">
                  <i class="bi bi-exclamation-octagon-fill me-2"></i>
                  <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                </div>
              {% endif %}

              {% if app.user %}
                <div class="alert alert-info py-2 small mb-3 d-flex align-items-center">
                  <i class="bi bi-info-circle-fill me-2"></i>
                  <div>
                    Ya estás autenticado como <strong>{{ app.user.userIdentifier }}</strong>.
                    <a href="{{ logout_path() }}" class="alert-link">Cerrar sesión</a>
                  </div>
                </div>
              {% endif %}

              <div class="form-floating mb-3">
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" placeholder="nombre@ejemplo.com" required autofocus />
                <label for="username"><i class="bi bi-envelope me-1"></i> Correo Electrónico</label>
              </div>

              <div class="form-floating mb-3">
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" placeholder="Contraseña" required />
                <label for="password"><i class="bi bi-key me-1"></i> Contraseña</label>
              </div>

              <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

              <div class="d-grid mt-4">
                <button class="btn btn-lg btn-primary shadow-sm" type="submit"><i class="bi bi-key-fill me-2"></i>Ingresar al panel</button>
              </div>
            </form>
          </div>
        </div>

        <div class="text-center mt-3">
          <a href="{{ path('app_inicio') }}" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left"></i> Volver al menú principal</a>
        </div>
      </div>
    </div>
  </main>
{% endblock %}
