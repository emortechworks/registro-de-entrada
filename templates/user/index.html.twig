{% extends 'base.html.twig' %}

{% block title %}
  Listado de Usuarios
{% endblock %}

{% block body %}
  <main class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><i class="bi bi-people-fill me-2"></i>Listado de Usuarios</h1>
    </div>
    <table class="table table-hover align-middle p-2">
      <thead class="table-dark">
        <tr>
          <th>Nombre</th>
          <th>Apellido</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        {% for user in users %}
          <tr class="align-middle">
            <td>{{ user.nombre }}</td>
            <td>{{ user.apellido }}</td>
            <td class="text-center">
              <div class="btn-group" role="group">
                <a href="{{ path('app_user_show', { id: user.id }) }}" class="btn btn-outline-info btn-sm" title="Ver detalle"><i class="bi bi-eye"></i></a>
                <a href="{{ path('app_user_edit', { id: user.id }) }}" class="btn btn-outline-warning btn-sm" title="Editar"><i class="bi bi-pencil"></i></a>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="4" class="text-center text-muted">
              <i class="bi bi-exclamation-circle"></i>No se encontraron registros
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <div class="d-flex justify-content-between align-items-center m-4">
      <a href="{{ path('app_register') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Crear nuevo</a>
    </div>
  </main>
{% endblock %}
