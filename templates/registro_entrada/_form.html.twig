            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="mb-3">
                {{ form_label(form.motivo_de_visita, 'Motivo', { 'label_attr': {'class': 'form-label'} }) }}
                {{ form_widget(form.motivo_de_visita, { 'attr': {'class': 'form-control'} }) }}
                {{ form_errors(form.motivo_de_visita) }}
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary ms-2" type="submit">
        <i class="bi bi-save me-1" aria-hidden="true"></i> {{ button_label|default('Guardar') }}
        </button>
    </div>

{{ form_end(form) }}
