
{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    {# Render hidden token explicitly if present #}
    {% if form._token is defined %}
        {{ form_widget(form._token) }}
    {% endif %}

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="mb-3">
                {{ form_label(form.nombre, 'Nombre', { 'label_attr': {'class': 'form-label'} }) }}
                {{ form_widget(form.nombre, { 'attr': {'class': 'form-control'} }) }}
                {{ form_errors(form.nombre) }}
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="mb-3">
                {{ form_label(form.apellido, 'Apellido', { 'label_attr': {'class': 'form-label'} }) }}
                {{ form_widget(form.apellido, { 'attr': {'class': 'form-control'} }) }}
                {{ form_errors(form.apellido) }}
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="mb-3">
                {{ form_label(form.identificacion, 'Identificación', { 'label_attr': {'class': 'form-label'} }) }}
                {{ form_widget(form.identificacion, { 'attr': {'class': 'form-control'} }) }}
                {{ form_errors(form.identificacion) }}
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="mb-3">
                {{ form_label(form.persona_que_visita, 'Persona que visita', { 'label_attr': {'class': 'form-label'} }) }}
                {{ form_widget(form.persona_que_visita, { 'attr': {'class': 'form-control'} }) }}
                {{ form_errors(form.persona_que_visita) }}
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="mb-3">
                {{ form_label(form.departamento_que_visita, 'Departamento', { 'label_attr': {'class': 'form-label'} }) }}
