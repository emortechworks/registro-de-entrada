{% extends 'base.html.twig' %}

{% block title %}
  Edit RegistroEntrada
{% endblock %}

{% block body %}
  <div class="container py-4">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h1 class="h5 mb-0"><i class="bi bi-pencil me-2" aria-hidden="true"></i> Editar registro</h1>
        <div>{{ include('registro_entrada/_delete_form.html.twig') }}</div>
      </div>
      <div class="card-body">
        {{ include('registro_entrada/_form.html.twig', { button_label: 'Actualizar' }) }}

        <div class="mt-3">
          <a href="{{ path('app_registro_entrada_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Volver</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
