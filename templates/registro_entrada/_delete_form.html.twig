<form method="post" action="{{ path('app_registro_entrada_delete', { id: registro_entrada.id }) }}" onsubmit="return confirm('¿Seguro que desea eliminar este elemento?');" class="d-inline">
  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ registro_entrada.id) }}" />
  <button class="btn btn-danger btn-sm"><i class="bi bi-trash me-1" aria-hidden="true"></i> Eliminar</button>
</form>
